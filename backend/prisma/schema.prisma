generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum Severity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum BountyStatus {
  DRAFT
  OPEN
  UNDER_REVIEW
  COMPLETED
  EXPIRED
  REFUNDED
}

enum ReportStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
  PAID
}

enum ReviewDecision {
  APPROVE
  REJECT
}

enum TransactionType {
  CREATE_BOUNTY
  LOCK_REWARD
  SUBMIT_REPORT
  APPROVE_REPORT
  REJECT_REPORT
  RELEASE_REWARD
  CLAIM_REWARD
  REFUND
}

enum TransactionStatus {
  PENDING
  SUCCESS
  FAILED
}

model User {
  id           String        @id @default(uuid()) @db.Uuid
  email        String        @unique
  username     String        @unique
  passwordHash String
  avatarUrl    String?
  role         UserRole      @default(USER)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  wallets      Wallet[]
  bounties     Bounty[]      @relation("BountyOwner")
  reports      Report[]      @relation("ReportHunter")
  reviews      Review[]      @relation("ReviewReviewer")
  transactions Transaction[]
}

model Wallet {
  id            String    @id @default(uuid()) @db.Uuid
  userId        String    @db.Uuid
  walletAddress String    @unique
  isPrimary     Boolean   @default(false)
  nonce         String?
  verifiedAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Bounty {
  id                 String        @id @default(uuid()) @db.Uuid
  ownerId            String        @db.Uuid
  onchainBountyId    String?
  title              String
  description        String
  scope              String
  severity           Severity
  rewardAmount       Decimal       @db.Decimal(20, 7)
  rewardAsset        String        @default("XLM")
  deadline           DateTime
  status             BountyStatus  @default(OPEN)
  metadataHash       String?
  txHash             String?       @unique
  stellarExplorerUrl String?
  refundTxHash       String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  owner              User          @relation("BountyOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  reports            Report[]
  transactions       Transaction[]

  @@index([ownerId])
  @@index([severity])
  @@index([status])
}

model Report {
  id                 String        @id @default(uuid()) @db.Uuid
  bountyId           String        @db.Uuid
  hunterId           String        @db.Uuid
  onchainReportId    String?
  title              String
  severity           Severity
  description        String
  stepsToReproduce   String
  impact             String
  recommendation     String
  reportHash         String?
  txHash             String?       @unique
  stellarExplorerUrl String?
  approveTxHash      String?
  rejectTxHash       String?
  claimTxHash        String?
  status             ReportStatus  @default(DRAFT)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  bounty             Bounty        @relation(fields: [bountyId], references: [id], onDelete: Restrict)
  hunter             User          @relation("ReportHunter", fields: [hunterId], references: [id], onDelete: Restrict)
  reviews            Review[]
  transactions       Transaction[]

  @@index([bountyId])
  @@index([hunterId])
  @@index([status])
}

model Review {
  id         String         @id @default(uuid()) @db.Uuid
  reportId   String         @db.Uuid
  reviewerId String         @db.Uuid
  decision   ReviewDecision
  comment    String?
  createdAt  DateTime       @default(now())
  report     Report         @relation(fields: [reportId], references: [id], onDelete: Cascade)
  reviewer   User           @relation("ReviewReviewer", fields: [reviewerId], references: [id], onDelete: Restrict)

  @@index([reportId])
  @@index([reviewerId])
}

model Transaction {
  id        String            @id @default(uuid()) @db.Uuid
  userId    String            @db.Uuid
  bountyId  String?           @db.Uuid
  reportId  String?           @db.Uuid
  txHash    String?
  type      TransactionType
  status    TransactionStatus @default(PENDING)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  user      User              @relation(fields: [userId], references: [id], onDelete: Restrict)
  bounty    Bounty?           @relation(fields: [bountyId], references: [id], onDelete: SetNull)
  report    Report?           @relation(fields: [reportId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([bountyId])
  @@index([reportId])
  @@index([type])
  @@index([status])
}
