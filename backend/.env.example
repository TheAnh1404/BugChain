DATABASE_URL="postgresql://postgres:postgres@localhost:5432/bugchain?schema=public"
JWT_SECRET="replace-with-a-strong-secret"
JWT_EXPIRES_IN="7d"
REPORT_ENCRYPTION_KEY="0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef"
FRONTEND_URL="http://localhost:5173"

# Email delivery:
# - console: keep emails in terminal logs and /auth/dev-emails for local-only demos.
# - smtp: send verification/reset emails to the real address entered by the user.
EMAIL_PROVIDER="console"

# Local demo only: return the password reset link directly in the UI instead of
# sending reset email. This is rejected when NODE_ENV=production.
DEV_INLINE_PASSWORD_RESET_LINK=false

# Gmail example for real delivery:
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER="your-gmail-address@gmail.com"
# SMTP_PASS="your-16-character-google-app-password"
# SMTP_FROM="your-gmail-address@gmail.com"

SMTP_HOST=""
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""
VITE_CONTRACT_ID="CBRSQQ3WTR4S32JKUMO2E3MA6P3EX5IH6YC6FR4HWIZFC72TBRXBNSCS"
VITE_STELLAR_RPC_URL="https://soroban-testnet.stellar.org"
VITE_STELLAR_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"
ENABLE_STELLAR_TX_VALIDATION=false
SENTRY_DSN=""
SENTRY_TRACES_SAMPLE_RATE=0.1
LOG_LEVEL=info
PORT=3000
